// SETUP VLAN (CLI)
! S1
interface vlan 1
ip address 192.168.20.11 255.255.255.0
no shutdown
exit

! S2
interface vlan 1
ip address 192.168.20.12 255.255.255.0
no shutdown

! S3
interface vlan 1
ip address 192.168.20.13 255.255.255.0
no shutdown



// ASSIGN IP ADDRESSES TO ALL PCS
PC IP Address Subnet Mask
PC1 192.168.20.21 255.255.255.0
PC2 192.168.20.31 255.255.255.0
PC3 192.168.20.41 255.255.255.0
PC4 192.168.20.51 255.255.255.0


// TEST PING (OPTIONAL)
! COMMAND PROMPT
ping 192.168.20.31
ping 192.168.20.41
