// SETUP SWITCHES (CLI)
! S1
enable
configure terminal
hostname S1
line console 0
password <yourpassword>
login
exit

enable password <yourpassword>
banner motd $Your message here$
clock set HH:MM:SS DD Month YYYY
copy run start

